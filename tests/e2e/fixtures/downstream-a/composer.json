{
  "name": "dxs/e2e-downstream-a",
  "type": "project",
  "require": {
    "php": "^8.3",
    "dxs/laravel-auth": "@dev",
    "laravel/framework": "^12.0"
  },
  "repositories": [{ "type": "path", "url": "__PACKAGE_ROOT__", "options": { "symlink": false } }],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": { "psr-4": { "App\\": "app/" } },
  "scripts": { "post-autoload-dump": ["@php artisan package:discover --ansi"] }
}
